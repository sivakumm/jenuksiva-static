{
  "name": "jenuksiva",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/sivakumm/jenuksiva-static#readme",
  "bugs": {
    "url": "https://github.com/sivakumm/jenuksiva-static/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sivakumm/jenuksiva-static.git"
  },
  "license": "ISC",
  "author": "Mithusan Sivakumar",
  "type": "commonjs",
  "main": "script.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "http-server ./docs -p 8080 -g",
    "start:dev": "http-server ./page -p 8080 -g",
    "build": "npm run clean && npm run create:docs && npm run copy:assets && npm run copy:cname && npm run copy:robots && npm run minify:css && npm run minify:html",
    "clean": "rimraf ./docs/",
    "create:docs": "mkdir docs",
    "copy:assets": "cp -r ./page/assets ./docs/assets",
    "copy:cname": "cp ./page/CNAME ./docs/CNAME",
    "copy:robots": "cp ./page/robots.txt ./docs/robots.txt",
    "minify:css": "minify ./page/style.css > ./docs/style.css",
    "minify:html": "minify ./page/index.html > ./docs/index.html"
  },
  "devDependencies": {
    "http-server": "14.1.1",
    "minify": "15.2.0",
    "rimraf": "6.1.3"
  }
}
